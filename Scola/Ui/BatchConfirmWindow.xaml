<Window x:Class="XHub.Scola.BatchConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zuordnung prüfen"
        Width="580" SizeToContent="Height" MaxHeight="680"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        Background="#FFFFFF" FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="C.Text" Color="#1E2530" />
        <SolidColorBrush x:Key="C.TextSecondary" Color="#5A6573" />
        <SolidColorBrush x:Key="C.TextSubtle" Color="#8B95A4" />
        <SolidColorBrush x:Key="C.Border" Color="#E4E8EE" />
        <SolidColorBrush x:Key="C.FieldBg" Color="#F3F5F8" />
        <SolidColorBrush x:Key="C.Btn" Color="#EDEFF3" />
        <SolidColorBrush x:Key="C.BtnHover" Color="#E2E6EC" />
        <SolidColorBrush x:Key="C.BtnBorder" Color="#D5DBE3" />

        <Style x:Key="C.Chip" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource C.FieldBg}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="C.Button" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource C.Text}" />
            <Setter Property="Background" Value="{StaticResource C.Btn}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource C.BtnBorder}" BorderThickness="1" CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource C.BtnHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22,20,22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Kopf -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock x:Name="TitleText" Text="Zuordnung prüfen" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource C.Text}" />
            <TextBlock Text="Jede Zeile wird beim Teilnehmer daneben eingetragen. Bitte Reihenfolge prüfen."
                       FontSize="12" Foreground="{StaticResource C.TextSecondary}"
                       Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Zuordnungsliste -->
        <Border Grid.Row="1" BorderBrush="{StaticResource C.Border}" BorderThickness="1" CornerRadius="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="440" Padding="10">
                <ItemsControl x:Name="RowsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FFFFFF" BorderBrush="{StaticResource C.Border}"
                                    BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="26" Height="26" CornerRadius="13"
                                            Background="{StaticResource C.FieldBg}" VerticalAlignment="Top"
                                            Margin="0,0,12,0">
                                        <TextBlock Text="{Binding Index}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource C.TextSecondary}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource C.Text}" />
                                        <WrapPanel Margin="0,6,0,0">
                                            <Border Style="{StaticResource C.Chip}">
                                                <TextBlock Text="{Binding Date}" FontSize="11"
                                                           Foreground="{StaticResource C.TextSecondary}" />
                                            </Border>
                                            <Border Style="{StaticResource C.Chip}">
                                                <TextBlock Text="{Binding Initials}" FontSize="11"
                                                           Foreground="{StaticResource C.TextSecondary}" />
                                            </Border>
                                            <Border Style="{StaticResource C.Chip}">
                                                <TextBlock Text="{Binding Type}" FontSize="11"
                                                           Foreground="{StaticResource C.TextSecondary}" />
                                            </Border>
                                        </WrapPanel>
                                        <TextBlock Text="{Binding Text}" FontSize="12"
                                                   Foreground="{StaticResource C.TextSubtle}"
                                                   Margin="0,5,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Aktionen -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Abbrechen" Style="{StaticResource C.Button}" Margin="0,0,10,0"
                    Click="Cancel_OnClick" />
            <Button x:Name="ConfirmButton" Content="Eintragen" Style="{StaticResource C.Button}"
                    Click="Confirm_OnClick" />
        </StackPanel>
    </Grid>
</Window>
