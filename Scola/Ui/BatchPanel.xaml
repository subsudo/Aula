<UserControl x:Class="XHub.Scola.BatchPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="380" d:DesignHeight="700">
    <UserControl.Resources>
        <SolidColorBrush x:Key="B.PanelBg" Color="#FFFFFF" />
        <SolidColorBrush x:Key="B.FieldBg" Color="#F3F5F8" />
        <SolidColorBrush x:Key="B.Text" Color="#1E2530" />
        <SolidColorBrush x:Key="B.TextSecondary" Color="#5A6573" />
        <SolidColorBrush x:Key="B.TextSubtle" Color="#8B95A4" />
        <SolidColorBrush x:Key="B.Border" Color="#E4E8EE" />
        <SolidColorBrush x:Key="B.Btn" Color="#EDEFF3" />
        <SolidColorBrush x:Key="B.BtnHover" Color="#E2E6EC" />
        <SolidColorBrush x:Key="B.BtnBorder" Color="#D5DBE3" />

        <Style x:Key="B.Card" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource B.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="B.SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource B.TextSubtle}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <SolidColorBrush x:Key="B.Hover" Color="#EDF1F7" />

        <!-- Klappbarer Sektions-Header (ToggleButton mit Chevron) -->
        <Style x:Key="B.CollapsibleHeader" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="8" Padding="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter VerticalAlignment="Center" />
                                <TextBlock x:Name="Chevron" Grid.Column="1" Text="&#xE70D;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{StaticResource B.TextSubtle}"
                                           VerticalAlignment="Center" Margin="6,0,2,0" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Chevron" Property="Text" Value="&#xE70E;" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource B.Hover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="B.Input" TargetType="TextBox">
            <Setter Property="MinHeight" Value="58" />
            <Setter Property="MaxHeight" Value="160" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Background" Value="{StaticResource B.FieldBg}" />
            <Setter Property="Foreground" Value="{StaticResource B.Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource B.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="9" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="B.Button" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource B.Text}" />
            <Setter Property="Background" Value="{StaticResource B.Btn}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource B.BtnBorder}" BorderThickness="1" CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource B.BtnHover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="B.IconTrash" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource B.TextSubtle}" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Width" Value="36" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource B.Hover}" />
                                <Setter Property="Foreground" Value="#D17878" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="B.ResultLine" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Margin" Value="0,1,0,1" />
            <Setter Property="Foreground" Value="#C0392B" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                    <Setter Property="Foreground" Value="#2E7D32" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="B.ResultTemplate">
            <TextBlock Style="{StaticResource B.ResultLine}">
                <Run Text="{Binding Name, Mode=OneWay}" />
                <Run Text="  –  " />
                <Run Text="{Binding Message, Mode=OneWay}" />
            </TextBlock>
        </DataTemplate>

        <DataTemplate x:Key="B.BiTodoTemplate">
            <TextBlock Style="{StaticResource B.ResultLine}">
                <Run Text="{Binding DisplayName, Mode=OneWay}" />
                <Run Text="  –  " />
                <Run Text="{Binding Message, Mode=OneWay}" />
            </TextBlock>
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="{StaticResource B.PanelBg}" CornerRadius="14">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Batch-Einträge" FontSize="17" FontWeight="SemiBold"
                           Foreground="{StaticResource B.Text}" />
                <TextBlock x:Name="HeaderHint"
                           Text="Eine Zeile pro Teilnehmer · Format: Datum  Kürzel  Art  Text"
                           FontSize="11.5" Foreground="{StaticResource B.TextSecondary}"
                           Margin="0,3,0,0" TextWrapping="Wrap" />
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- BU -->
                    <Border Style="{StaticResource B.Card}">
                        <StackPanel>
                            <ToggleButton Style="{StaticResource B.CollapsibleHeader}" Tag="{Binding ElementName=BuBody}"
                                          IsChecked="False" Checked="Section_OnToggle" Unchecked="Section_OnToggle">
                                <TextBlock Text="BU-EINTRAG" Style="{StaticResource B.SectionTitle}" Margin="0" />
                            </ToggleButton>
                            <StackPanel x:Name="BuBody" Visibility="Collapsed" Margin="0,10,0,0">
                                <TextBox x:Name="BuInput" Style="{StaticResource B.Input}" />
                                <Grid Margin="0,8,0,0">
                                    <TextBlock x:Name="BuStatus" Foreground="{StaticResource B.TextSubtle}"
                                               FontSize="11" VerticalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Style="{StaticResource B.IconTrash}" Content="&#xE74D;"
                                                ToolTip="Eingabe leeren" Tag="BU" Click="ClearBatchInput_OnClick"
                                                Margin="0,0,8,0" />
                                        <Button Content="Ausführen" Style="{StaticResource B.Button}"
                                                Tag="BU" Click="RunBatch_OnClick" />
                                    </StackPanel>
                                </Grid>
                                <ItemsControl x:Name="BuResults" ItemTemplate="{StaticResource B.ResultTemplate}"
                                              Margin="0,8,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- BI -->
                    <Border Style="{StaticResource B.Card}">
                        <StackPanel>
                            <ToggleButton Style="{StaticResource B.CollapsibleHeader}" Tag="{Binding ElementName=BiBody}"
                                          IsChecked="False" Checked="Section_OnToggle" Unchecked="Section_OnToggle">
                                <TextBlock Text="BI-EINTRAG" Style="{StaticResource B.SectionTitle}" Margin="0" />
                            </ToggleButton>
                            <StackPanel x:Name="BiBody" Visibility="Collapsed" Margin="0,10,0,0">
                                <TextBox x:Name="BiInput" Style="{StaticResource B.Input}" />
                                <Grid Margin="0,8,0,0">
                                    <TextBlock x:Name="BiStatus" Foreground="{StaticResource B.TextSubtle}"
                                               FontSize="11" VerticalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Style="{StaticResource B.IconTrash}" Content="&#xE74D;"
                                                ToolTip="Eingabe leeren" Tag="BI" Click="ClearBatchInput_OnClick"
                                                Margin="0,0,8,0" />
                                        <Button Content="Ausführen" Style="{StaticResource B.Button}"
                                                Tag="BI" Click="RunBatch_OnClick" />
                                    </StackPanel>
                                </Grid>
                                <ItemsControl x:Name="BiResults" ItemTemplate="{StaticResource B.ResultTemplate}"
                                              Margin="0,8,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- LB -->
                    <Border Style="{StaticResource B.Card}">
                        <StackPanel>
                            <ToggleButton Style="{StaticResource B.CollapsibleHeader}" Tag="{Binding ElementName=LbBody}"
                                          IsChecked="False" Checked="Section_OnToggle" Unchecked="Section_OnToggle">
                                <TextBlock Text="LB-EINTRAG" Style="{StaticResource B.SectionTitle}" Margin="0" />
                            </ToggleButton>
                            <StackPanel x:Name="LbBody" Visibility="Collapsed" Margin="0,10,0,0">
                                <TextBox x:Name="LbInput" Style="{StaticResource B.Input}" />
                                <Grid Margin="0,8,0,0">
                                    <TextBlock x:Name="LbStatus" Foreground="{StaticResource B.TextSubtle}"
                                               FontSize="11" VerticalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Style="{StaticResource B.IconTrash}" Content="&#xE74D;"
                                                ToolTip="Eingabe leeren" Tag="LB" Click="ClearBatchInput_OnClick"
                                                Margin="0,0,8,0" />
                                        <Button Content="Ausführen" Style="{StaticResource B.Button}"
                                                Tag="LB" Click="RunBatch_OnClick" />
                                    </StackPanel>
                                </Grid>
                                <ItemsControl x:Name="LbResults" ItemTemplate="{StaticResource B.ResultTemplate}"
                                              Margin="0,8,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- BI-To-do Sammeldokument -->
                    <Border Style="{StaticResource B.Card}" Margin="0">
                        <StackPanel>
                            <ToggleButton Style="{StaticResource B.CollapsibleHeader}" Tag="{Binding ElementName=BiTodoBody}"
                                          IsChecked="False" Checked="Section_OnToggle" Unchecked="Section_OnToggle">
                                <TextBlock Text="BI-TO-DO SAMMELDOKUMENT" Style="{StaticResource B.SectionTitle}" Margin="0" />
                            </ToggleButton>
                            <StackPanel x:Name="BiTodoBody" Visibility="Collapsed" Margin="0,10,0,0">
                                <TextBlock Text="Zieht die BI-To-do-Tabellen aller Tray-Teilnehmer in ein gemeinsames Word-Dokument."
                                           FontSize="11.5" Foreground="{StaticResource B.TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,0,0,8" />
                                <Grid>
                                    <TextBlock x:Name="BiTodoStatus" Foreground="{StaticResource B.TextSubtle}"
                                               FontSize="11" VerticalAlignment="Center" />
                                    <Button Content="Sammeln" Style="{StaticResource B.Button}"
                                            HorizontalAlignment="Right" Click="RunBiTodo_OnClick" />
                                </Grid>
                                <ItemsControl x:Name="BiTodoResults" ItemTemplate="{StaticResource B.BiTodoTemplate}"
                                              Margin="0,8,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
