<Window x:Class="XHub.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einstellungen"
        Icon="pack://application:,,,/Assets/icon.ico"
        Width="720"
        SizeToContent="Height"
        MinWidth="560"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.WindowBg}"
        Foreground="{DynamicResource Brush.PrimaryText}">
    <Window.Resources>

        <!-- Einheitlicher Karten-Kopf: Titel + dezente Beschreibung -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
        </Style>

        <Style x:Key="SectionSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.SecondaryText}" />
            <Setter Property="Margin" Value="0,2,0,10" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.SecondaryText}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="FieldHintStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.SubtleText}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="Margin" Value="0,3,0,0" />
        </Style>

        <Style x:Key="TileCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.PanelBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16,12" />
        </Style>

        <!-- Eingabefeld: Standard-TextBox in runder Huelle (bewaehrt, kein Retemplating) -->
        <Style x:Key="InputWrapStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.PanelBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="WrappedInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Brush.AccentHover}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Brush.AccentHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Brush.AccentPressed}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Brush.AccentPressed}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.PanelBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Brush.CardHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Aktionen-Kachel: angehakt = warme Akzent-Toenung statt harter Box -->
        <Style x:Key="ActionCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Chrome"
                                Background="{DynamicResource Brush.PanelBg}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,6"
                                MinWidth="104">
                            <DockPanel>
                                <Border x:Name="Indicator"
                                        DockPanel.Dock="Left"
                                        Width="16"
                                        Height="16"
                                        CornerRadius="5"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1"
                                        Margin="0,0,8,0">
                                    <TextBlock x:Name="IndicatorText"
                                               Text=""
                                               FontSize="11"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#FFFFFF" />
                                </Border>
                                <ContentPresenter VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Brush.CardHover}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Brush.AccentSubtle}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource Brush.Accent}" />
                                <Setter TargetName="Indicator" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                <Setter TargetName="IndicatorText" Property="Text" Value="✓" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Schlichte Checkbox-Zeile (ohne Kachel-Optik) -->
        <Style x:Key="InlineCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <DockPanel Background="Transparent">
                            <Border x:Name="Indicator"
                                    DockPanel.Dock="Left"
                                    Width="16"
                                    Height="16"
                                    CornerRadius="5"
                                    Background="{DynamicResource Brush.PanelBg}"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="IndicatorText"
                                           Text=""
                                           FontSize="11"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#FFFFFF" />
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" />
                        </DockPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Indicator" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource Brush.Accent}" />
                                <Setter TargetName="Indicator" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                <Setter TargetName="IndicatorText" Property="Text" Value="✓" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dezenter Text-Button (Fusszeile) -->
        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource Brush.SecondaryText}" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="Transparent" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Brush.CardHover}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource Brush.PanelBg}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,0,1"
                Padding="24,12">
            <Grid>
                <TextBlock Text="Einstellungen"
                           FontSize="15"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="Abbrechen"
                            Width="104"
                            Margin="0,0,8,0"
                            Style="{StaticResource SecondaryHeaderButtonStyle}"
                            Click="CancelButton_OnClick" />
                    <Button Content="Speichern"
                            Width="104"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="SaveButton_OnClick" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False">
            <StackPanel Margin="24,16,24,14">

                <!-- Pfade -->
                <Border Style="{StaticResource TileCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Pfade" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Ablageorte der Teilnehmenden-Ordner auf dem Server"
                                   Style="{StaticResource SectionSubtitleStyle}" />

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Lehrvorbereitung (LV)" Style="{StaticResource FieldLabelStyle}" />
                            <Border Grid.Column="1" Style="{StaticResource InputWrapStyle}">
                                <TextBox x:Name="ServerPathTextBox" Style="{StaticResource WrappedInputStyle}" />
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Lehrbegleitung (LB)" Style="{StaticResource FieldLabelStyle}" />
                            <Border Grid.Column="1" Style="{StaticResource InputWrapStyle}">
                                <TextBox x:Name="LbPathTextBox" Style="{StaticResource WrappedInputStyle}" />
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Start" Style="{StaticResource FieldLabelStyle}" />
                            <Border Grid.Column="1" Style="{StaticResource InputWrapStyle}">
                                <TextBox x:Name="StartPathTextBox" Style="{StaticResource WrappedInputStyle}" />
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Austritte" Style="{StaticResource FieldLabelStyle}" />
                            <Border Grid.Column="1" Style="{StaticResource InputWrapStyle}">
                                <TextBox x:Name="ExitPathTextBox" Style="{StaticResource WrappedInputStyle}" />
                            </Border>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Stundenplan" Style="{StaticResource FieldLabelStyle}"
                                       VerticalAlignment="Top" Margin="0,7,0,0" />
                            <StackPanel Grid.Column="1">
                                <Border Style="{StaticResource InputWrapStyle}">
                                    <TextBox x:Name="SchedulePathTextBox" Style="{StaticResource WrappedInputStyle}" />
                                </Border>
                                <TextBlock Text="DOCX-Datei oder Ordner mit Wochenplaenen"
                                           Style="{StaticResource FieldHintStyle}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Einträge -->
                <Border Style="{StaticResource TileCardStyle}" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="Einträge" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Vorbefüllung beim Einfügen von Einträgen"
                                   Style="{StaticResource SectionSubtitleStyle}" />

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox x:Name="AutoPrefillEntryCheckBox"
                                      Style="{StaticResource InlineCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      Content="Datum und Kürzel automatisch vorfüllen" />
                            <TextBlock Text="Kürzel"
                                       Style="{StaticResource FieldLabelStyle}"
                                       Margin="24,0,8,0" />
                            <Border Style="{StaticResource InputWrapStyle}" Width="140"
                                    IsEnabled="{Binding IsChecked, ElementName=AutoPrefillEntryCheckBox}">
                                <TextBox x:Name="DefaultEntryInitialsTextBox"
                                         Style="{StaticResource WrappedInputStyle}"
                                         IsEnabled="{Binding IsChecked, ElementName=AutoPrefillEntryCheckBox}" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Aktionen -->
                <Border Style="{StaticResource TileCardStyle}" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="Aktionen" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Sichtbare Buttons an den Teilnehmenden-Kacheln"
                                   Style="{StaticResource SectionSubtitleStyle}" />
                        <WrapPanel>
                            <CheckBox x:Name="FolderActionCheckBox"   Style="{StaticResource ActionCheckBoxStyle}" Content="Ordner" />
                            <CheckBox x:Name="DocumentActionCheckBox" Style="{StaticResource ActionCheckBoxStyle}" Content="Akte" />
                            <CheckBox x:Name="BuActionCheckBox"       Style="{StaticResource ActionCheckBoxStyle}" Content="BU" />
                            <CheckBox x:Name="BiActionCheckBox"       Style="{StaticResource ActionCheckBoxStyle}" Content="BI" />
                            <CheckBox x:Name="BeActionCheckBox"       Style="{StaticResource ActionCheckBoxStyle}" Content="BE" />
                            <CheckBox x:Name="LbActionCheckBox"       Style="{StaticResource ActionCheckBoxStyle}" Content="LB" />
                            <CheckBox x:Name="EntryBuActionCheckBox"  Style="{StaticResource ActionCheckBoxStyle}" Content="Eintrag BU" />
                            <CheckBox x:Name="EntryBiActionCheckBox"  Style="{StaticResource ActionCheckBoxStyle}" Content="Eintrag BI" />
                            <CheckBox x:Name="EntryBeActionCheckBox"  Style="{StaticResource ActionCheckBoxStyle}" Content="Eintrag BE" />
                            <CheckBox x:Name="EntryLbActionCheckBox"  Style="{StaticResource ActionCheckBoxStyle}" Content="Eintrag LB" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Fusszeile -->
                <Grid Margin="2,6,2,0">
                    <Button Content="Logs öffnen"
                            HorizontalAlignment="Left"
                            Style="{StaticResource LinkButtonStyle}"
                            Click="OpenLogFolderButton_OnClick" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="UpdateStatusTextBlock"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   Foreground="{DynamicResource Brush.SecondaryText}"
                                   FontSize="11.5" />
                        <Button x:Name="CheckUpdatesButton"
                                Content="Nach Updates suchen"
                                Style="{StaticResource LinkButtonStyle}"
                                Click="CheckUpdatesButton_OnClick" />
                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
